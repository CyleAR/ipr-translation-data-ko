  "data": {
    "card-hrk-05-link-00|0|1|evolveMessage": "마나 언니와 같은 무대에\\n설 수 있는 날이 올 거라고, 믿고 있어",
    "card-hrk-05-link-00|0|2|evolveMessage": "하루코가 다음에 울 때는\\n행복한, 기쁨의 눈물이야",
    "card-hrk-05-link-00|1|1|evolveMessage": "드디어 같은 무대에 섰어",
    "card-hrk-05-link-00|1|2|evolveMessage": "이 날이 오길 기다렸어",
    "card-kan-05-link-00|0|1|evolveMessage": "자~ 그럼, 이 멍청한 얼굴에\\n뭘 그려버릴까",
    "card-kan-05-link-00|0|2|evolveMessage": "얼굴에 낙서하는 건 반칙이에요!?",
    "card-kan-05-link-00|1|1|evolveMessage": "꽤 하는데~?",
    "card-kan-05-link-00|1|2|evolveMessage": "당연하죠!",
    "card-kkr-05-link-00|0|1|evolveMessage": "활짝 핀 우리 둘의 모습,\\n눈에 새겨주세요!",
    "card-kkr-05-link-00|0|2|evolveMessage": "이번 여름, 가장\\n뜨거운 스테이지로\\n만들어 보일테니까요!",
    "card-kkr-05-link-00|1|1|evolveMessage": "합숙의 성과!",
    "card-kkr-05-link-00|1|2|evolveMessage": "제대로 보여주자!",
    "card-mna-05-link-00|0|1|evolveMessage": "코토노는 내 자랑스러운 여동생이야",
    "card-mna-05-link-00|0|2|evolveMessage": "…… 언니…",
    "card-mna-05-link-00|1|1|evolveMessage": "가자‚ 코토노!",
    "card-mna-05-link-00|1|2|evolveMessage": "기다려‚ 언니!",
    "card-ski-05-link-00|0|1|evolveMessage": "치사‚ 간지러운 데 없어?",
    "card-ski-05-link-00|0|2|evolveMessage": "응, 다음엔 내가 씻겨줄게?",
    "card-ski-05-link-00|1|1|evolveMessage": "가자‚ 치사",
    "card-ski-05-link-00|1|2|evolveMessage": "같이 힘내자‚ 언니!",
    "card-suz-05-link-00|0|1|evolveMessage": "어, 어째서 이렇게,\\n메이의 차는 빠른 건가요!?",
    "card-suz-05-link-00|0|2|evolveMessage": "아하하, 이번엔\\n스즈냥이\\n쫓을 차례네~",
    "card-suz-05-link-00|1|1|evolveMessage": "이게 바로 멍냥 트윈즈의!",
    "card-suz-05-link-00|1|2|evolveMessage": "두근두근한 매력이야~!",
    "card-szk-05-link-00|0|1|evolveMessage": "내 청춘에는,\n항상 곁에\n치사 언니가 있어 줬어",
    "card-szk-05-link-00|0|2|evolveMessage": "내가 용기를 낼 수 있는 건,\n시즈쿠 덕분이야",
    "card-szk-05-link-00|1|1|evolveMessage": "우리의 관계는――",
    "card-szk-05-link-00|1|2|evolveMessage": "――물론, 절친이야!",
    "card-yu-05-link-00|0|1|evolveMessage": "나,\n참말로 루이가 좋다",
    "card-yu-05-link-00|0|2|evolveMessage": "나는 더더욱 네가 좋아졌다",
    "card-yu-05-link-00|1|1|evolveMessage": "앞으로도 함께",
    "card-yu-05-link-00|1|2|evolveMessage": "응‚ 함께 가자‚ 유우"
  }
}